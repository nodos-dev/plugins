{
    "release_globs": [
        "Config/**",
        "*.nosplugin",
        "Include/**",
        "Assets/**",
        "Binaries/*.{dll,dylib,so}",
        "Types/**"
    ],
    "trigger_publish_globs": [
        "Source/**",
        "CMakeLists.txt"
    ],
    "target_platforms": ["x86_64-windows"]
}