namespace nos.compositing;

enum TransitionType : uint {
	Dissolve = 0,
	WipeLeft = 1,
	WipeRight = 2,
	WipeUp = 3,
	WipeDown = 4
}

enum TransitionInterpolation : uint {
	Jump = 0,
	Linear = 1,
	Step = 2,
	EaseIn = 3,
	EaseOut = 4,
	EaseInOut = 5
}

enum TransitionTarget : uint {
	Input2 = 0,
	Input1 = 1
}