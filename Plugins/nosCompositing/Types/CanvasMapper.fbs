include "Builtins.fbs";
include "Types/Types.fbs";

namespace nos.compositing;

enum BlendMode : uint {
  Normal = 0,
  Additive = 1
}

table CanvasLayer
{
    texture: nos.sys.vulkan.Texture;
    position: nos.fb.vec2;
    rotation: float;
	origin: nos.fb.vec2;
    size: nos.fb.vec2u;
	blend_mode: BlendMode;
	opacity: float;
}