          ], "comments": [
            {
              "id": "a241bba0-b2e2-428b-a804-e2bf76ccbc76",
              "name": "Comment (8)",
              "hint": "Hint",
              "content": "Copy output texture to different texture every frame provided by the texture provider node\ninside the graph. They are then pushed to the object queue at the end of the producer thread.",
              "pos": { "x": 1499.0, "y": 829.0 },
              "size": { "x": 570.0, "y": 242.0 },
              "bg_color": { "x": 0.0, "y": 0.548673, "z": 1.0, "w": 0.3 }
            },
            {
              "id": "87611819-820d-479d-8e1e-9a11264d0313",
              "name": "Comment (5)",
              "hint": "Hint",
              "content": "Queues texture composite objects into the bounded queue to be used by the consumer thread. Schedules producer thread execution when a slot is available in the bounded queue.",
              "pos": { "x": 2049.0, "y": 780.0 },
              "size": { "x": 490.0, "y": 144.0 },
              "bg_color": { "x": 0.884955, "y": 0.0, "z": 1.0, "w": 0.3 }
            },
            {
              "id": "779a5799-c4e5-461e-a935-3eb5dc7d4492",
              "name": "Comment (9)",
              "hint": "Hint",
              "content": "Starts the GPU copy of texture object pulled from bounded\nqueue to a new texture object and signals the texture providers\nthat host use of this texture object is finished.",
              "pos": { "x": 2519.0, "y": 771.0 },
              "size": { "x": 394.0, "y": 160.0 },
              "bg_color": { "x": 0.60177, "y": 0.575143, "z": 0.0, "w": 0.3 }
            }
          ], "connections": [
